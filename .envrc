# Load devbox environment (provides rustup, cargo, bun, etc.)
eval "$(devbox shellenv --init-hook 2>/dev/null)" 2>/dev/null || true

# Load local secrets (never committed)
dotenv_if_exists .env

# Development flags
export CST_DEV=1
export RUST_BACKTRACE=1
export RUST_LOG=cst=debug,warn

# Project root
export CST_PROJECT_ROOT="$(pwd)"
